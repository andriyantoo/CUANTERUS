{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "git": {
    "deploymentEnabled": {
      "main": true
    }
  },
  "crons": [
    {
      "path": "/api/cron/check-expiry",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/follow-up",
      "schedule": "0 9 * * *"
    }
  ]
}
